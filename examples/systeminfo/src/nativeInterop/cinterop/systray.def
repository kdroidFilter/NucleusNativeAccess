compilerOpts.linux_x64 = \
    -I/usr/include/glib-2.0 \
    -I/usr/lib/x86_64-linux-gnu/glib-2.0/include \
    -I/usr/include/gio-unix-2.0 \
    -I/usr/include/libdbusmenu-glib-0.4

linkerOpts.linux_x64 = -L/usr/lib/x86_64-linux-gnu -lgio-2.0 -lgobject-2.0 -lglib-2.0 -ldbusmenu-glib

---

#include <gio/gio.h>
#include <libdbusmenu-glib/server.h>
#include <libdbusmenu-glib/menuitem.h>
#include <string.h>
#include <stdio.h>
#include <unistd.h>

static GDBusConnection *_sni_conn = NULL;
static guint _sni_reg_id = 0;
static guint _sni_bus_id = 0;
static GMainLoop *_sni_loop = NULL;
static GThread *_sni_thread = NULL;
static GDBusNodeInfo *_sni_intro = NULL;
static DbusmenuServer *_sni_menu_server = NULL;
static char *_sni_title = NULL;
static char *_sni_body = NULL;
static void (*_sni_click_fn)(int) = NULL;

static const gchar _sni_xml[] =
    "<node>"
    "  <interface name='org.kde.StatusNotifierItem'>"
    "    <method name='Activate'>"
    "      <arg type='i' name='x' direction='in'/>"
    "      <arg type='i' name='y' direction='in'/>"
    "    </method>"
    "    <method name='SecondaryActivate'>"
    "      <arg type='i' name='x' direction='in'/>"
    "      <arg type='i' name='y' direction='in'/>"
    "    </method>"
    "    <method name='ContextMenu'>"
    "      <arg type='i' name='x' direction='in'/>"
    "      <arg type='i' name='y' direction='in'/>"
    "    </method>"
    "    <method name='Scroll'>"
    "      <arg type='i' name='delta' direction='in'/>"
    "      <arg type='s' name='orientation' direction='in'/>"
    "    </method>"
    "    <signal name='NewTitle'/>"
    "    <signal name='NewIcon'/>"
    "    <signal name='NewStatus'>"
    "      <arg type='s' name='status'/>"
    "    </signal>"
    "    <signal name='NewToolTip'/>"
    "    <property name='Category' type='s' access='read'/>"
    "    <property name='Id' type='s' access='read'/>"
    "    <property name='Title' type='s' access='read'/>"
    "    <property name='Status' type='s' access='read'/>"
    "    <property name='IconName' type='s' access='read'/>"
    "    <property name='IconThemePath' type='s' access='read'/>"
    "    <property name='ToolTip' type='(sa(iiay)ss)' access='read'/>"
    "    <property name='ItemIsMenu' type='b' access='read'/>"
    "    <property name='Menu' type='o' access='read'/>"
    "  </interface>"
    "</node>";

static void _sni_method_call(
    GDBusConnection *conn, const gchar *sender, const gchar *path,
    const gchar *iface, const gchar *method, GVariant *params,
    GDBusMethodInvocation *invocation, gpointer data)
{
    g_dbus_method_invocation_return_value(invocation, NULL);
}

static GVariant* _sni_get_prop(
    GDBusConnection *conn, const gchar *sender, const gchar *path,
    const gchar *iface, const gchar *prop, GError **err, gpointer data)
{
    if (g_strcmp0(prop, "Category") == 0)
        return g_variant_new_string("SystemServices");
    if (g_strcmp0(prop, "Id") == 0)
        return g_variant_new_string("kotlin-systeminfo");
    if (g_strcmp0(prop, "Title") == 0)
        return g_variant_new_string(_sni_title ? _sni_title : "System Info");
    if (g_strcmp0(prop, "Status") == 0)
        return g_variant_new_string("Active");
    if (g_strcmp0(prop, "IconName") == 0)
        return g_variant_new_string("computer");
    if (g_strcmp0(prop, "IconThemePath") == 0)
        return g_variant_new_string("");
    if (g_strcmp0(prop, "ItemIsMenu") == 0)
        return g_variant_new_boolean(TRUE);
    if (g_strcmp0(prop, "Menu") == 0)
        return g_variant_new_object_path("/MenuBar");
    if (g_strcmp0(prop, "ToolTip") == 0) {
        GVariantBuilder b;
        g_variant_builder_init(&b, G_VARIANT_TYPE("a(iiay)"));
        return g_variant_new("(sa(iiay)ss)", "computer", &b,
            _sni_title ? _sni_title : "System Info",
            _sni_body ? _sni_body : "");
    }
    return NULL;
}

static const GDBusInterfaceVTable _sni_vtable = {
    _sni_method_call, _sni_get_prop, NULL
};

static gpointer _sni_run(gpointer data) {
    g_main_loop_run((GMainLoop*)data);
    return NULL;
}

static void _sni_bus_acquired(GDBusConnection *conn, const gchar *name, gpointer data) {
    GError *err = NULL;
    _sni_conn = conn;
    _sni_reg_id = g_dbus_connection_register_object(
        conn, "/StatusNotifierItem",
        _sni_intro->interfaces[0], &_sni_vtable,
        NULL, NULL, &err);
    if (err) g_error_free(err);
}

static void _sni_name_acquired(GDBusConnection *conn, const gchar *name, gpointer data) {
    GError *err = NULL;
    g_dbus_connection_call_sync(conn,
        "org.kde.StatusNotifierWatcher",
        "/StatusNotifierWatcher",
        "org.kde.StatusNotifierWatcher",
        "RegisterStatusNotifierItem",
        g_variant_new("(s)", name),
        NULL, G_DBUS_CALL_FLAGS_NONE, -1, NULL, &err);
    if (err) g_error_free(err);
}

#define SNI_MAX_ITEMS 32
static DbusmenuMenuitem *_sni_items[SNI_MAX_ITEMS];
static int _sni_item_count = 0;

static void _sni_item_activated(DbusmenuMenuitem *item, guint timestamp, gpointer data) {
    int index = GPOINTER_TO_INT(data);
    if (_sni_click_fn) _sni_click_fn(index);
}

static void systray_set_click_callback(void (*cb)(int)) {
    _sni_click_fn = cb;
}

static int systray_show_dbus(const char* title, const char** labels, int count) {
    if (_sni_loop != NULL) return 0;

    _sni_title = g_strdup(title);
    GString *body = g_string_new(NULL);
    for (int i = 0; i < count; i++) {
        if (i > 0) g_string_append_c(body, '\n');
        g_string_append(body, labels[i]);
    }
    _sni_body = g_string_free(body, FALSE);

    _sni_intro = g_dbus_node_info_new_for_xml(_sni_xml, NULL);
    if (!_sni_intro) return 0;

    /* Build dbusmenu */
    _sni_item_count = count < SNI_MAX_ITEMS ? count : SNI_MAX_ITEMS;
    DbusmenuMenuitem *root = dbusmenu_menuitem_new();
    for (int i = 0; i < _sni_item_count; i++) {
        DbusmenuMenuitem *item = dbusmenu_menuitem_new();
        dbusmenu_menuitem_property_set(item, DBUSMENU_MENUITEM_PROP_LABEL, labels[i]);
        dbusmenu_menuitem_property_set_bool(item, DBUSMENU_MENUITEM_PROP_ENABLED, TRUE);
        g_signal_connect(item, DBUSMENU_MENUITEM_SIGNAL_ITEM_ACTIVATED,
            G_CALLBACK(_sni_item_activated), GINT_TO_POINTER(i));
        dbusmenu_menuitem_child_append(root, item);
        _sni_items[i] = item;
    }
    _sni_menu_server = dbusmenu_server_new("/MenuBar");
    dbusmenu_server_set_root(_sni_menu_server, root);

    _sni_loop = g_main_loop_new(NULL, FALSE);

    char bus_name[128];
    snprintf(bus_name, sizeof(bus_name),
        "org.kde.StatusNotifierItem-%d-1", getpid());

    _sni_bus_id = g_bus_own_name(G_BUS_TYPE_SESSION, bus_name,
        G_BUS_NAME_OWNER_FLAGS_NONE,
        _sni_bus_acquired, _sni_name_acquired,
        NULL, NULL, NULL);

    _sni_thread = g_thread_new("sni", _sni_run, _sni_loop);
    return 1;
}

static int systray_update_label(int index, const char* label) {
    if (index < 0 || index >= _sni_item_count || !_sni_items[index]) return 0;
    dbusmenu_menuitem_property_set(_sni_items[index], DBUSMENU_MENUITEM_PROP_LABEL, label);
    return 1;
}

static int systray_hide_dbus(void) {
    if (_sni_loop == NULL) return 0;

    if (_sni_reg_id > 0 && _sni_conn)
        g_dbus_connection_unregister_object(_sni_conn, _sni_reg_id);
    if (_sni_bus_id > 0)
        g_bus_unown_name(_sni_bus_id);
    if (_sni_menu_server) {
        g_object_unref(_sni_menu_server);
        _sni_menu_server = NULL;
    }

    g_main_loop_quit(_sni_loop);
    g_thread_join(_sni_thread);
    g_main_loop_unref(_sni_loop);

    _sni_loop = NULL;
    _sni_thread = NULL;
    _sni_conn = NULL;
    _sni_reg_id = 0;
    _sni_bus_id = 0;

    g_dbus_node_info_unref(_sni_intro);
    _sni_intro = NULL;
    g_free(_sni_title);  _sni_title = NULL;
    g_free(_sni_body);   _sni_body = NULL;
    for (int i = 0; i < _sni_item_count; i++) _sni_items[i] = NULL;
    _sni_item_count = 0;

    return 1;
}
