headers = gio/gio.h
headerFilter = gio/**
package = gio

compilerOpts.linux_x64 = \
    -I/usr/include/glib-2.0 \
    -I/usr/lib/x86_64-linux-gnu/glib-2.0/include \
    -I/usr/include/gio-unix-2.0

linkerOpts.linux_x64 = -L/usr/lib/x86_64-linux-gnu -lgio-2.0 -lgobject-2.0 -lglib-2.0

---

#include <gio/gio.h>
#include <glib.h>
#include <stdlib.h>
#include <stdio.h>
#include <string.h>

typedef struct {
    GMainLoop *loop;
    char *path;
} ScreenshotContext;

static void on_portal_response(GDBusConnection *conn, const gchar *sender, const gchar *path,
                               const gchar *iface, const gchar *signal, GVariant *params,
                               gpointer data) {
    ScreenshotContext *ctx = (ScreenshotContext *)data;
    guint32 response;
    GVariant *results = NULL;
    g_variant_get(params, "(u@a{sv})", &response, &results);

    fprintf(stderr, "[DEBUG_LOG] Screenshot: Portal response: %u\n", response);

    if (response == 0) {
        GVariant *uri_v = g_variant_lookup_value(results, "uri", G_VARIANT_TYPE_STRING);
        if (uri_v) {
            const char *uri = g_variant_get_string(uri_v, NULL);
            GError *err = NULL;
            char *filename = g_filename_from_uri(uri, NULL, &err);
            if (filename) {
                ctx->path = strdup(filename);
                g_free(filename);
                fprintf(stderr, "[DEBUG_LOG] Screenshot: Path extracted: %s\n", ctx->path);
            } else {
                if (err) {
                    fprintf(stderr, "[DEBUG_LOG] Screenshot: Failed to convert URI to filename: %s\n", err->message);
                    g_error_free(err);
                }
            }
            g_variant_unref(uri_v);
        }
    } else {
        fprintf(stderr, "[DEBUG_LOG] Screenshot: Capture failed or cancelled by user (response %u)\n", response);
    }
    if (results) g_variant_unref(results);
    g_main_loop_quit(ctx->loop);
}

static char* capture_screenshot_portal(void) {
    GError *error = NULL;
    GDBusConnection *conn = g_bus_get_sync(G_BUS_TYPE_SESSION, NULL, &error);
    if (!conn) {
        if (error) {
            fprintf(stderr, "[DEBUG_LOG] Screenshot: D-Bus connection error: %s\n", error->message);
            g_error_free(error);
        }
        return NULL;
    }

    ScreenshotContext ctx = { g_main_loop_new(NULL, FALSE), NULL };

    char handle_token[64];
    snprintf(handle_token, sizeof(handle_token), "kscreenshot%u", g_random_int());

    const char *unique_name_raw = g_dbus_connection_get_unique_name(conn);
    char *sender = g_malloc(strlen(unique_name_raw) + 1);
    const char *p_in = unique_name_raw;
    char *p_out = sender;
    while (*p_in) {
        if (*p_in == ':') {
            p_in++;
            continue;
        }
        if (*p_in == '.') {
            *p_out = '_';
        } else {
            *p_out = *p_in;
        }
        p_in++;
        p_out++;
    }
    *p_out = '\0';

    char request_path[256];
    snprintf(request_path, sizeof(request_path), "/org/freedesktop/portal/desktop/request/%s/%s", sender, handle_token);
    g_free(sender);

    fprintf(stderr, "[DEBUG_LOG] Screenshot: Subscribing to path: %s\n", request_path);

    guint sub_id = g_dbus_connection_signal_subscribe(conn, NULL,
                                                      "org.freedesktop.portal.Request", "Response",
                                                      request_path, NULL, G_DBUS_SIGNAL_FLAGS_NONE,
                                                      on_portal_response, &ctx, NULL);

    GVariantBuilder opt_builder;
    g_variant_builder_init(&opt_builder, G_VARIANT_TYPE("a{sv}"));
    g_variant_builder_add(&opt_builder, "{sv}", "handle_token", g_variant_new_string(handle_token));
    g_variant_builder_add(&opt_builder, "{sv}", "interactive", g_variant_new_boolean(TRUE));

    fprintf(stderr, "[DEBUG_LOG] Screenshot: Calling Portal Screenshot method...\n");

    GVariant *res = g_dbus_connection_call_sync(conn, "org.freedesktop.portal.Desktop",
                                                "/org/freedesktop/portal/desktop",
                                                "org.freedesktop.portal.Screenshot", "Screenshot",
                                                g_variant_new("(s@a{sv})", "", g_variant_builder_end(&opt_builder)),
                                                G_VARIANT_TYPE("(o)"), G_DBUS_CALL_FLAGS_NONE, -1, NULL, &error);

    if (res) {
        const char *returned_path;
        g_variant_get(res, "(&o)", &returned_path);
        fprintf(stderr, "[DEBUG_LOG] Screenshot: Portal returned handle: %s\n", returned_path);

        g_main_loop_run(ctx.loop);
        g_variant_unref(res);
    } else {
        if (error) {
            fprintf(stderr, "[DEBUG_LOG] Screenshot: Portal method call failed: %s\n", error->message);
            g_error_free(error);
        }
    }

    g_dbus_connection_signal_unsubscribe(conn, sub_id);
    g_main_loop_unref(ctx.loop);
    g_object_unref(conn);

    return ctx.path;
}
