headers = gio/gio.h
headerFilter = gio/** glib/** gobject/**
package = gio

compilerOpts.linux_x64 = \
    -I/usr/include/glib-2.0 \
    -I/usr/lib/x86_64-linux-gnu/glib-2.0/include \
    -I/usr/include/gio-unix-2.0

linkerOpts.linux_x64 = -L/usr/lib/x86_64-linux-gnu -lgio-2.0 -lgobject-2.0 -lglib-2.0
