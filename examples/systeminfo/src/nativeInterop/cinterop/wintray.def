package = wintray
headers = windows.h shellapi.h objbase.h shlobj.h propvarutil.h propkey.h
compilerOpts.mingw_x64 = -DWINVER=0x0A00 -D_WIN32_WINNT=0x0A00 -DNTDDI_VERSION=0x0A000000 -DUNICODE -D_UNICODE
linkerOpts.mingw_x64 = -lshell32 -luser32 -lole32 -loleaut32 -luxtheme

---

#include <windows.h>
#include <shellapi.h>
#include <objbase.h>
#include <shlobj.h>
#include <propvarutil.h>
#include <propkey.h>
